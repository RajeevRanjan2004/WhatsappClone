{
  "expo": {
    "name": "PulseChat Mobile",
    "slug": "pulsechat-mobile",
    "scheme": "pulsechat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "backgroundColor": "#0b141a",
      "resizeMode": "contain"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b141a",
          "resizeMode": "contain"
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b141a"
      },
      "package": "com.pulsechat.mobile",
      "versionCode": 1
    },
    "ios": {
      "bundleIdentifier": "com.pulsechat.mobile"
    },
    "extra": {
      "eas": {
        "projectId": "dfca1137-3957-412b-80e0-cd5278534648"
      }
    }
  }
}
