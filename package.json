{
  "name": "whatsapp-clone",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "server": "npm run dev --workspace server",
    "client": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "mobile": "npm run start --prefix mobile",
    "mobile:android": "npm run android --prefix mobile",
    "mobile:web": "npm run web --prefix mobile"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
